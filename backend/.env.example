# ===========================================
# Bol Monitor — copy to backend/.env
#   copy backend\.env.example backend\.env
# ===========================================

# ===========================================
# Neon PostgreSQL — SAME URL on PC and Render
# login-bol.bat saves Bol cookies into this database.
# Paste your Neon connection string below:
# ===========================================
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/neondb?sslmode=require
# Local-only fallback (no PC↔Render session sync — not for this project):
# DATABASE_URL=sqlite:///./data/bol_monitor.db

APP_NAME=Bol Monitor
API_PORT=8003
SECRET_KEY=change-this-secret-key-in-production
# Local + your Vercel frontend URL (comma-separated) after deploy:
CORS_ORIGINS=http://localhost:5175,http://127.0.0.1:5175
# Example: CORS_ORIGINS=http://localhost:5175,https://your-app.vercel.app

ADMIN_EMAIL=
ADMIN_PASSWORD=

# On Render set these in the dashboard (do not commit secrets):
# DATABASE_URL=...
# SECRET_KEY=<long-random-string>
# CORS_ORIGINS=https://your-frontend.vercel.app
# ADMIN_EMAIL=...          ← live login email (this backend only)
# ADMIN_PASSWORD=...       ← live login password (synced on every boot)
# Local uses backend/.env ADMIN_* ; Render uses dashboard ADMIN_* .
# Same Neon DB is fine — each backend accepts its own env login.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

DISCORD_WEBHOOK_URL=

USE_PROXIES=0

SITEMAP_SCAN_INTERVAL_SEC=600
POLL_ONLINE_MIN=5
POLL_ONLINE_MAX=10
POLL_OFFLINE_MIN=40
POLL_OFFLINE_MAX=60
